# ─────────────────────────────────────────────────────────────────────────────
# LMS product (msq-lms) — leads-service, meta-conversion-api,
# notifications-service, lms-web.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection (shared cluster — see msq-core) ──────────────────
DB_NAME=crm
DB_HOST=localhost
DB_PORT=5432
# Hostname of msq-core's Postgres container (see its cross-repo networking note).
DB_CONTAINER_NAME=crm-db-server

# Per-product DB login role (P1.2/D8, created by db_scripts/19 — currently
# shipped whole in msq-core, see its README). Reads/writes only
# lms/marketing/ext + read-only iam/entity/geo.
DB_LMS_SVC_USER=lms_svc
DB_LMS_SVC_PASSWORD=LmsSvc_Dev2025
DB_SERVICE_USER=root_service
DB_SERVICE_PASSWORD=CrmSvc_Dev2025

DATABASE_URL=postgres://lms_svc:LmsSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm
# Tells @platform/db's withRoleTx to skip `SET LOCAL ROLE app_user` — required
# for the per-product login, see db_scripts/19_init-per-product-db-grants.sql.
DB_PRODUCT_SCOPED_LOGIN=true

PG_MAX=10
PG_IDLE_TIMEOUT=30
PG_SSL_MODE=disable

# ── Auth (must match msq-core's identity-service exactly) ─────────────────
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_PUBLIC_KEY=    # RS256 verification — preferred over JWT_SECRET, see msq-core
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string

# API key for the intake webhook endpoint (pre-shared with ad platform integrations)
WEBHOOK_API_KEY=change-me-webhook-key

# Meta credential encryption (app_secret + page access_token stored at rest).
# 32-byte key as 64 hex chars or base64. REQUIRED in production; if unset in dev,
# Meta credentials are stored in plaintext. Generate: openssl rand -hex 32
# META_ENCRYPTION_KEY=

# Allow unsigned Meta webhooks (skips HMAC when no signature header is present).
# Must be false/unset in production; only for local testing without a real app secret.
ALLOW_UNSIGNED_WEBHOOKS=true

FOLLOWUP_CHECK_INTERVAL_MS=60000
FOLLOWUP_LOOKAHEAD_MINUTES=5

# ─────────────────────────────────────────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────────────────────────────────────────
LEADS_SERVICE_PORT=4002
META_SERVICE_PORT=4003
NOTIFICATIONS_SERVICE_PORT=4004

# ── Internal service URLs (this repo's services + the shared gateway) ───────
API_GATEWAY_INTERNAL_URL=http://localhost:4000
LEADS_SERVICE_URL=http://localhost:4002
META_SERVICE_URL=http://localhost:4003
NOTIFICATIONS_SERVICE_URL=http://localhost:4004

NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# lms-web (Next.js) → lms.app.com
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_LMS_URL=http://localhost:3001
NEXT_PUBLIC_HR_URL=http://localhost:3002
NEXT_PUBLIC_TASK_URL=http://localhost:3003
NEXT_PUBLIC_PASSWORD_MIN_LENGTH=12
COOKIE_SECURE=false
